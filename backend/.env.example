# Server settings
PORT=5000
NODE_ENV=development

# Database connection
# Adjust localhost:5432 to postgres:5432 if running backend inside Docker Network
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/foodlens_db?schema=public"

# Authentication Secrets
JWT_ACCESS_SECRET="super-secret-access-token-key-change-me"
JWT_REFRESH_SECRET="super-secret-refresh-token-key-change-me"

# Google Gemini API
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"

# Storage Settings: 'local' or 'supabase'
STORAGE_PROVIDER="local"

# Supabase Storage Configuration (only needed if STORAGE_PROVIDER="supabase")
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_BUCKET="foodlens-images"
